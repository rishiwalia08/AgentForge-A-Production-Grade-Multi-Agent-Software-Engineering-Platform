# Environment Configuration Template
ENVIRONMENT=production

# Database Settings
# For local SQLite: sqlite:///./data/agent_memory.db
# For production PostgreSQL: postgresql+psycopg2://postgres:password@postgres:5432/agentic_ai
DATABASE_URL=postgresql+psycopg2://postgres:postgres@postgres:5432/agentic_ai

# Redis settings (used for Celery Broker and Pub/Sub Event Bus)
# For local fallback: redis://localhost:6379/0
REDIS_URL=redis://redis:6379/0

# Ollama LLM endpoint
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# JWT Authentication
JWT_SECRET=production-jwt-secret-replace-me-with-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=2592000

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id-here
GOOGLE_CLIENT_SECRET=your-google-client-secret-here
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Frontend URL for CORS configuration
FRONTEND_URL=http://localhost:3000
