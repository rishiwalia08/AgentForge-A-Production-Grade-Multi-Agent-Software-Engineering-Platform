#   check them in.
# .python-version

# pipenv
#   According to pypa/pipenv#598, it is recommended to include Pipfile.lock in version control.
#   However, if you're executing a library that should be compatible with multiple Python versions,
#   you might want to ignore Pipfile.lock.
#Pipfile.lock

# poetry
#   Similar to Pipenv, it is generally recommended to include poetry.lock in version control.
#   poetry.lock

# pdm
